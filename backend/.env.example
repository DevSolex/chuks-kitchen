# Local Docker Compose (MySQL)
DB_URL=mysql+pymysql://chuks:secret@db:3306/chuks_kitchen

# On Render, DB_URL is set automatically from the managed PostgreSQL database.
# Use a postgresql:// URL if connecting to any external PostgreSQL instance.

SECRET_KEY=your_secret_key_here

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Comma-separated list of allowed frontend origins
# e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=["*"]
